rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isMasterAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'matiaschababo@gmail.com' ||
        request.auth.token.email == 'manzo.coinary@gmail.com' ||
        request.auth.token.email == 'pitta.visual.garden@gmail.com'
      );
    }

    // Resultados globales
    match /global/results {
      allow read: if true;
      allow write: if isMasterAdmin(); 
    }

    // Predicciones
    match /predictions/{userId} {
      allow read: if true;
      // Solo el dueño o un admin puede modificar sus predicciones
      allow write: if request.auth != null && (request.auth.uid == userId || isMasterAdmin());
    }

    // Usuarios (Perfiles, Roles)
    match /users/{userId} {
      allow read: if true;
      // El propio usuario puede editar su info, o el admin puede editar cualquier usuario (asignar roles)
      allow write: if (request.auth != null && request.auth.uid == userId) || isMasterAdmin();
    }
  }
}
